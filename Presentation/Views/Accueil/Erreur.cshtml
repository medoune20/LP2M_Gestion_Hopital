@{
    ViewData["Title"] = "Erreur";
}

<div class="gh-content">
    <div class="gh-card mx-auto" style="max-width:760px;margin-top:3rem">
        <div class="gh-card-body text-center p-5">
            <div class="mb-3 text-danger" style="font-size:3rem"><i class="bi bi-exclamation-triangle"></i></div>
            <h1 class="fw-bold mb-2">Erreur de chargement</h1>
            <p class="text-muted mb-4">La page demandee n'a pas pu etre chargee. Consultez les logs du conteneur pour identifier la cause exacte.</p>
            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <a class="btn btn-primary" href="@Url.Action("Index", "Accueil")"><i class="bi bi-house me-1"></i>Retour accueil</a>
                <a class="btn btn-outline-primary" href="@Url.Action("Index", "Lp2m")"><i class="bi bi-grid-1x2 me-1"></i>Administration LP2M</a>
                <a class="btn btn-outline-secondary" href="@Url.Action("Connexion", "Auth")"><i class="bi bi-box-arrow-in-right me-1"></i>Connexion</a>
            </div>
        </div>
    </div>
</div>
