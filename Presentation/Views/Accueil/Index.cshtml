@{
    ViewData["Title"] = "Tableau de bord";
    var labels = ViewBag.GraphLabels as List<string> ?? new();
    var dataRdv = ViewBag.GraphRDV as List<int> ?? new();
    var dataConsult = ViewBag.GraphConsult as List<int> ?? new();
    var rdvJour = ViewBag.RDVJour as List<RendezVous> ?? new();
    var hosps = ViewBag.Hospitalisations as List<Hospitalisation> ?? new();
    var depts = ViewBag.Departements as List<Departement> ?? new();
    string nomHopital = ViewBag.NomHopital ?? "Hôpital";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h1 class="fw-bold mb-1"><i class="bi bi-speedometer2 me-2 text-primary"></i>Tableau de bord</h1>
        <p class="text-muted mb-0">@nomHopital — @DateTime.Now.ToString("dddd dd MMMM yyyy") &nbsp;<span id="gh-clock" class="fw-semibold"></span></p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Patient/Nouveau" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Nouveau patient</a>
        <a href="/RendezVous/Nouveau" class="btn btn-outline-primary d-none d-md-inline-flex"><i class="bi bi-calendar-plus me-1"></i>Nouveau RDV</a>
    </div>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card metric-card text-center">
            <div class="card-body">
                <div class="metric-label">Total patients</div>
                <div class="metric-value text-primary">@ViewBag.TotalPatients</div>
                <i class="bi bi-people metric-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card metric-card text-center">
            <div class="card-body">
                <div class="metric-label">Hospitalisés</div>
                <div class="metric-value text-warning">@ViewBag.PatientsHospitalisés</div>
                <i class="bi bi-hospital-fill metric-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card metric-card text-center">
            <div class="card-body">
                <div class="metric-label">RDV aujourd'hui</div>
                <div class="metric-value text-info">@ViewBag.RDVAujourdhui</div>
                <i class="bi bi-calendar-check metric-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card metric-card text-center">
            <div class="card-body">
                <div class="metric-label">Consultations</div>
                <div class="metric-value text-success">@ViewBag.ConsultationsAujourdhui</div>
                <i class="bi bi-clipboard2-pulse metric-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card metric-card text-center">
            <div class="card-body">
                <div class="metric-label">Lits libres</div>
                <div class="metric-value text-secondary">@ViewBag.LitsLibres</div>
                <i class="bi bi-bed metric-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card metric-card text-center">
            <div class="card-body">
                <div class="metric-label">Médecins actifs</div>
                <div class="metric-value text-primary">@ViewBag.TotalMédecins</div>
                <i class="bi bi-person-badge metric-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <a href="/Examen" class="card metric-card text-center text-decoration-none">
            <div class="card-body">
                <div class="metric-label">Examens en attente</div>
                <div class="metric-value text-danger">@ViewBag.ExamensPending</div>
                <i class="bi bi-droplet-half metric-icon"></i>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
        <a href="/FileAttente" class="card metric-card text-center text-decoration-none">
            <div class="card-body">
                <div class="metric-label">File d'attente</div>
                <div class="metric-value text-info"><i class="bi bi-arrow-right-circle"></i></div>
                <i class="bi bi-person-lines-fill metric-icon"></i>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Graphique activité -->
    <div class="col-12 col-lg-8">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2"></i>Activité des 7 derniers jours</h6>
                <canvas id="chartActivite" height="110"></canvas>
            </div>
        </div>
    </div>
    <!-- Capacité services -->
    <div class="col-12 col-lg-4">
        <div class="card h-100">
            <div class="card-body p-0">
                <div class="d-flex justify-content-between align-items-center p-3 pb-0">
                    <h6 class="fw-bold mb-0"><i class="bi bi-diagram-3 me-2"></i>Services</h6>
                    <a href="/Departement" class="btn btn-sm btn-outline-primary">Voir tout</a>
                </div>
                @foreach (var dept in depts.Take(6))
                {
                    var libre = dept.LitsLibres;
                    var total = dept.Lits.Count;
                    var pct = total > 0 ? (int)((double)(total - libre) / total * 100) : 0;
                    var couleur = pct >= 90 ? "danger" : pct >= 70 ? "warning" : "success";
                    <div class="px-3 py-2 border-bottom">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold" style="font-size:.88rem">@dept.Nom</span>
                            <small class="text-muted">@libre/@total libres</small>
                        </div>
                        <div class="progress" style="height:6px;border-radius:3px">
                            <div class="progress-bar bg-@couleur" style="width:@pct%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- RDV du jour -->
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body p-0">
                <div class="d-flex justify-content-between align-items-center p-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-calendar3 me-2"></i>Rendez-vous du jour</h6>
                    <a href="/RendezVous" class="btn btn-sm btn-outline-primary">Voir tout</a>
                </div>
                @if (!rdvJour.Any())
                {
                    <div class="text-center text-muted py-4 pb-3"><i class="bi bi-calendar-x fs-2 d-block mb-2 opacity-25"></i>Aucun rendez-vous aujourd'hui</div>
                }
                else
                {
                    @foreach (var rdv in rdvJour)
                    {
                        <div class="d-flex align-items-center gap-3 px-3 py-2 border-bottom">
                            <span class="fw-bold text-primary" style="width:44px;font-size:.9rem">@rdv.DateHeure.ToString("HH:mm")</span>
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-semibold text-truncate">@rdv.Patient?.NomComplet</div>
                                <div class="text-muted text-truncate" style="font-size:.78rem">@rdv.Medecin?.NomComplet &middot; @rdv.Motif</div>
                            </div>
                            <span class="badge text-bg-@rdv.StatutCssClass flex-shrink-0">@rdv.Statut</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <!-- Hospitalisations -->
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body p-0">
                <div class="d-flex justify-content-between align-items-center p-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-hospital-fill me-2"></i>Patients hospitalisés</h6>
                    <a href="/Hospitalisation" class="btn btn-sm btn-outline-primary">Voir tout</a>
                </div>
                @if (!hosps.Any())
                {
                    <div class="text-center text-muted py-4 pb-3"><i class="bi bi-house fs-2 d-block mb-2 opacity-25"></i>Aucun patient hospitalisé</div>
                }
                else
                {
                    @foreach (var h in hosps)
                    {
                        <div class="d-flex align-items-center gap-3 px-3 py-2 border-bottom">
                            <i class="bi bi-hospital text-primary fs-5 flex-shrink-0"></i>
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-semibold text-truncate">@h.Patient?.NomComplet</div>
                                <div class="text-muted text-truncate" style="font-size:.78rem">@h.Departement?.Nom &middot; Lit @h.Lit?.Numéro &middot; J+@h.DuréeJours</div>
                            </div>
                            <a href="/Patient/Details/@h.PatientId" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                                <i class="bi bi-folder2"></i>
                            </a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
    var ctx = document.getElementById('chartActivite');
    if(!ctx) return;
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels)),
            datasets: [
                { label: 'Rendez-vous', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dataRdv)), backgroundColor: 'rgba(14,165,233,.7)', borderRadius:5 },
                { label: 'Consultations', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dataConsult)), backgroundColor: 'rgba(16,185,129,.7)', borderRadius:5 }
            ]
        },
        options: { responsive:true, plugins:{ legend:{ position:'top' } }, scales:{ y:{ beginAtZero:true, ticks:{ stepSize:1 } } } }
    });
})();
</script>
}
