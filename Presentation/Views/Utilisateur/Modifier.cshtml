@model Utilisateur
@{
    ViewData["Title"] = "Modifier utilisateur";
    var medecins = ViewBag.Medecins as List<Medecin> ?? new();
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <h1 class="gh-page-title"><i class="bi bi-pencil me-2"></i>Modifier — @Model.NomComplet</h1>
        <a href="@Url.Action("Index", "Utilisateur")" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

<div class="gh-content">
    <form method="post" action="@Url.Action("Modifier", "Utilisateur")">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="gh-card">
                    <div class="gh-card-body">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label fw-semibold">Login *</label><input type="text" name="Login" value="@Model.Login" class="form-control" required /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Nouveau mot de passe</label><input type="password" name="nouveauMotDePasse" class="form-control" autocomplete="new-password" placeholder="Laisser vide pour conserver" /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Nom *</label><input type="text" name="Nom" value="@Model.Nom" class="form-control" required /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Prénom *</label><input type="text" name="Prénom" value="@Model.Prénom" class="form-control" required /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Email</label><input type="email" name="Email" value="@Model.Email" class="form-control" /></div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Rôle</label>
                                <select name="Role" class="form-select">
                                    @foreach (RoleUtilisateur r in Enum.GetValues(typeof(RoleUtilisateur)))
                                    {
                                        if (Model.Role == r) { <option value="@((int)r)" selected>@r</option> }
                                        else { <option value="@((int)r)">@r</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Médecin lié</label>
                                <select name="MedecinId" class="form-select">
                                    <option value="">Aucun</option>
                                    @foreach (var m in medecins)
                                    {
                                        if (Model.MedecinId == m.Id) { <option value="@m.Id" selected>@m.NomComplet</option> }
                                        else { <option value="@m.Id">@m.NomComplet</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch">
                                    @if (Model.Actif)
                                    {
                                        <input class="form-check-input" type="checkbox" name="Actif" value="true" checked />
                                    }
                                    else
                                    {
                                        <input class="form-check-input" type="checkbox" name="Actif" value="true" />
                                    }
                                    <label class="form-check-label fw-semibold">Compte actif</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="gh-card">
                    <div class="gh-card-body d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-save me-2"></i>Enregistrer</button>
                        <a href="@Url.Action("Index", "Utilisateur")" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
