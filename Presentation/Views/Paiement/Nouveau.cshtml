@{
    ViewData["Title"] = "Nouveau paiement";
    var patients = ViewBag.Patients as List<GestionHopital.Domaine.Models.Patient> ?? new();
    var patientSelecte = ViewBag.PatientSelecte as GestionHopital.Domaine.Models.Patient;
    var consultSelecte = ViewBag.ConsultationSelecte as GestionHopital.Domaine.Models.Consultation;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a href="/Paiement" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h1 class="fw-bold mb-0"><i class="bi bi-cash-coin me-2 text-primary"></i>Nouveau paiement</h1>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post" asp-action="Nouveau">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Rechercher un patient</label>
                        <input type="text" id="recherchePatient" class="form-control"
                               placeholder="Nom, prénom ou n° dossier…" autocomplete="off"
                               value="@patientSelecte?.NomComplet">
                        <div id="suggestionsPatient" class="list-group mt-1"></div>
                        <input type="hidden" name="PatientId" id="patientIdSelecete"
                               value="@(ViewBag.PatientId ?? "")">
                    </div>

                    @if (consultSelecte != null)
                    {
                        <div class="alert alert-info py-2">
                            <i class="bi bi-clipboard2-pulse me-1"></i>
                            Consultation du @consultSelecte.DateHeure.ToString("dd/MM/yyyy") — @consultSelecte.Patient?.NomComplet
                        </div>
                        <input type="hidden" name="ConsultationId" value="@consultSelecte.Id">
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Libellé prestation</label>
                        <input type="text" name="LibellePrestation" class="form-control" required
                               placeholder="Ex: Consultation générale, Examen sanguin…"
                               value="@(consultSelecte != null ? "Consultation médicale" : "")">
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-7">
                            <label class="form-label fw-semibold">Montant (FCFA)</label>
                            <input type="number" name="Montant" class="form-control" required min="0" step="100" placeholder="0">
                        </div>
                        <div class="col-5">
                            <label class="form-label fw-semibold">Statut</label>
                            <select name="Statut" class="form-select">
                                <option value="1">Payé</option>
                                <option value="0">En attente</option>
                                <option value="2">Partiel</option>
                                <option value="4">Gratuit</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mode de paiement</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-check border rounded p-3 h-100" style="cursor:pointer">
                                    <input class="form-check-input" type="radio" name="ModePaiement" value="0" id="mEspeces" checked>
                                    <label class="form-check-label w-100" for="mEspeces">
                                        <i class="bi bi-cash text-success me-2 fs-5"></i><strong>Espèces</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check border rounded p-3 h-100" style="cursor:pointer">
                                    <input class="form-check-input" type="radio" name="ModePaiement" value="1" id="mMobile">
                                    <label class="form-check-label w-100" for="mMobile">
                                        <i class="bi bi-phone text-info me-2 fs-5"></i><strong>Mobile Money</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check border rounded p-3 h-100" style="cursor:pointer">
                                    <input class="form-check-input" type="radio" name="ModePaiement" value="2" id="mCarte">
                                    <label class="form-check-label w-100" for="mCarte">
                                        <i class="bi bi-credit-card text-primary me-2 fs-5"></i><strong>Carte bancaire</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check border rounded p-3 h-100" style="cursor:pointer">
                                    <input class="form-check-input" type="radio" name="ModePaiement" value="4" id="mGratuit">
                                    <label class="form-check-label w-100" for="mGratuit">
                                        <i class="bi bi-gift text-secondary me-2 fs-5"></i><strong>Gratuit</strong>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3" id="zoneNumeroMobile" style="display:none">
                        <label class="form-label fw-semibold">N° Mobile Money</label>
                        <input type="text" name="NumeroPaiementMobile" class="form-control" placeholder="+221 7X XXX XX XX">
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle me-2"></i>Enregistrer le paiement
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var inputP = document.getElementById('recherchePatient');
var divS = document.getElementById('suggestionsPatient');
var hiddenId = document.getElementById('patientIdSelecete');
if (inputP) {
    inputP.addEventListener('input', function () {
        var q = this.value.trim();
        if (q.length < 2) { divS.innerHTML = ''; return; }
        fetch('/Paiement/RechercherPatient?q=' + encodeURIComponent(q))
            .then(function(r){ return r.json(); })
            .then(function(data) {
                divS.innerHTML = '';
                data.forEach(function(p) {
                    var a = document.createElement('a');
                    a.className = 'list-group-item list-group-item-action';
                    a.href = '#';
                    a.textContent = p.nom + ' (' + p.dossier + ')';
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        inputP.value = p.nom;
                        hiddenId.value = p.id;
                        divS.innerHTML = '';
                    });
                    divS.appendChild(a);
                });
            });
    });
}
document.querySelectorAll('input[name="ModePaiement"]').forEach(function(r) {
    r.addEventListener('change', function() {
        document.getElementById('zoneNumeroMobile').style.display = this.value === '1' ? '' : 'none';
    });
});
</script>
}
