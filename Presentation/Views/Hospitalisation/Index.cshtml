@model List<Hospitalisation>
@{
    ViewData["Title"] = "Hospitalisations";
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-hospital-fill me-2"></i>Patients hospitalisés</h1>
            <p class="gh-page-subtitle">@ViewBag.TotalHospitalisés patients · @ViewBag.TotalLitsLibres lits libres</p>
        </div>
        <a href="/Hospitalisation/Nouvelle" class="btn btn-primary"><i class="bi bi-person-check me-1"></i>Nouvelle admission</a>
    </div>
</div>

<div class="gh-content">
    @if (!Model.Any())
    {
        <div class="gh-card">
            <div class="text-center text-muted py-5">
                <i class="bi bi-house fs-1 d-block mb-2"></i>Aucun patient hospitalisé actuellement.
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var h in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="gh-card gh-hosp-card h-100">
                        <div class="gh-card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-0">@h.Patient?.NomComplet</h5>
                                    <small class="text-muted">@h.Patient?.NuméroDossier</small>
                                </div>
                                <span class="badge bg-primary fs-6">J+@h.DuréeJours</span>
                            </div>
                            <dl class="gh-dl-sm">
                                <dt><i class="bi bi-diagram-3 me-1"></i>Service</dt><dd>@h.Departement?.Nom</dd>
                                <dt><i class="bi bi-bed me-1"></i>Lit</dt><dd>@h.Lit?.Numéro</dd>
                                <dt><i class="bi bi-person-badge me-1"></i>Médecin référent</dt><dd>@h.MedecinRéférent?.NomComplet</dd>
                                <dt><i class="bi bi-calendar-event me-1"></i>Admission</dt><dd>@h.DateAdmission.ToString("dd/MM/yyyy HH:mm")</dd>
                                <dt><i class="bi bi-file-text me-1"></i>Motif</dt><dd>@h.MotifAdmission</dd>
                            </dl>
                            <div class="d-flex gap-2 mt-3">
                                <a href="/Patient/Details/@h.PatientId" class="btn btn-sm btn-outline-primary flex-fill">
                                    <i class="bi bi-folder2-open me-1"></i>Dossier
                                </a>
                                <a href="/Hospitalisation/Sortie/@h.Id" class="btn btn-sm btn-warning flex-fill">
                                    <i class="bi bi-box-arrow-right me-1"></i>Sortie
                                </a>
                            </div>
                        </div>
                        <div class="gh-hosp-num">@h.NuméroHospitalisation</div>
                    </div>
                </div>
            }
        </div>
    }
</div>
