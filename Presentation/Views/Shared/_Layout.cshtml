@using Microsoft.AspNetCore.Http
@{
    var nom = Context.Session.GetString("UtilisateurNom") ?? "Utilisateur";
    var couleur = Context.Session.GetString("CouleurHopital") ?? (ViewBag.CouleurHopital as string) ?? "#0ea5e9";
    var connecte = (Context.Session.GetInt32("UtilisateurId") ?? 0) > 0;
}
<!DOCTYPE html>
<html lang="fr" style="--tenant-color:@couleur">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] — LP2M Santé</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/css/site.css")" rel="stylesheet" />
    <link href="@Url.Content("~/css/lp2m-hospital.css")" rel="stylesheet" />
    <meta name="theme-color" content="@couleur" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(connecte ? "lp2m-app" : "lp2m-public")" data-path-base="@Context.Request.PathBase">
@if (connecte)
{
    <header class="lp2m-topbar no-print">
        <button class="lp2m-burger d-lg-none" type="button" aria-label="Ouvrir le menu" onclick="document.body.classList.toggle('sidebar-open')"><i class="bi bi-list"></i></button>
        <a class="lp2m-brand" href="@Url.Action("Index", "Accueil")"><i class="bi bi-hospital-fill"></i><span>LP2M Santé</span></a>
        <div class="lp2m-topbar-right">
            <span id="lp2m-net" class="badge text-bg-warning" hidden><i class="bi bi-wifi-off me-1"></i>Hors-ligne</span>
            <span class="lp2m-user" title="@nom"><i class="bi bi-person-circle"></i><span class="d-none d-sm-inline">@nom</span></span>
            <a class="btn btn-sm lp2m-logout" href="@Url.Action("Deconnexion", "Auth")"><i class="bi bi-box-arrow-right"></i><span class="d-none d-sm-inline ms-1">Déconnexion</span></a>
        </div>
    </header>

    <div class="lp2m-backdrop d-lg-none" onclick="document.body.classList.remove('sidebar-open')"></div>

    <aside class="lp2m-sidebar no-print">
        <nav class="lp2m-nav">
            <div class="lp2m-nav-title">Pilotage</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Accueil")"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Lp2m")"><i class="bi bi-grid-1x2"></i><span>Hub LP2M</span></a>

            <div class="lp2m-nav-title">Patients</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Patient")"><i class="bi bi-person-lines-fill"></i><span>Dossiers patients</span></a>
            <a class="lp2m-link" href="@Url.Action("Nouveau", "Patient")"><i class="bi bi-person-plus"></i><span>Nouveau patient</span></a>

            <div class="lp2m-nav-title">Agenda</div>
            <a class="lp2m-link" href="@Url.Action("Index", "RendezVous")"><i class="bi bi-calendar3"></i><span>Rendez-vous</span></a>
            <a class="lp2m-link" href="@Url.Action("Nouveau", "RendezVous")"><i class="bi bi-calendar-plus"></i><span>Nouveau RDV</span></a>
            <a class="lp2m-link" href="@Url.Action("Calendrier", "RendezVous")"><i class="bi bi-calendar-week"></i><span>Calendrier</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "FileAttente")"><i class="bi bi-hourglass-split"></i><span>File d'attente</span></a>

            <div class="lp2m-nav-title">Soins</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Consultation")"><i class="bi bi-clipboard2-pulse"></i><span>Consultations</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Examen")"><i class="bi bi-droplet-half"></i><span>Examens & analyses</span></a>

            <div class="lp2m-nav-title">Hospitalisation</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Hospitalisation")"><i class="bi bi-hospital-fill"></i><span>Hospitalisations</span></a>
            <a class="lp2m-link" href="@Url.Action("Nouvelle", "Hospitalisation")"><i class="bi bi-person-check"></i><span>Nouvelle admission</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Departement")"><i class="bi bi-diagram-3"></i><span>Services & lits</span></a>

            <div class="lp2m-nav-title">Finance</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Paiement")"><i class="bi bi-cash-stack"></i><span>Paiements</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Comptabilite")"><i class="bi bi-journal-text"></i><span>Comptabilité</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Accueil")"><i class="bi bi-graph-up"></i><span>Statistiques</span></a>

            <div class="lp2m-nav-title">Communication</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Alerte")"><i class="bi bi-bell"></i><span>Alertes</span></a>
            <a class="lp2m-link" href="@Url.Action("Journal", "Mail")"><i class="bi bi-envelope"></i><span>Mails</span></a>
            <a class="lp2m-link" href="@Url.Action("Composer", "Mail")"><i class="bi bi-send"></i><span>Composer mail</span></a>

            <div class="lp2m-nav-title">Administration</div>
            <a class="lp2m-link" href="@Url.Action("Index", "Utilisateur")"><i class="bi bi-people"></i><span>Utilisateurs & rôles</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Etablissement")"><i class="bi bi-buildings"></i><span>Établissement</span></a>
            <a class="lp2m-link" href="@Url.Action("Index", "Medecin")"><i class="bi bi-person-badge"></i><span>Médecins</span></a>
        </nav>
    </aside>
}

<main class="lp2m-main container-fluid">
    @if (TempData["Succès"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-2"><i class="bi bi-check-circle me-2"></i>@TempData["Succès"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Erreur"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-2"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Erreur"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Avertissement"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show mt-2"><i class="bi bi-exclamation-circle me-2"></i>@TempData["Avertissement"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @RenderBody()
</main>

@if (connecte)
{
    <nav class="mobile-bottom-nav d-lg-none no-print">
        <a href="@Url.Action("Index", "Accueil")"><i class="bi bi-speedometer2"></i><span>Accueil</span></a>
        <a href="@Url.Action("Index", "Patient")"><i class="bi bi-person-lines-fill"></i><span>Patients</span></a>
        <a href="@Url.Action("Index", "RendezVous")" class="mobile-nav-pos"><i class="bi bi-calendar3"></i><span>RDV</span></a>
        <a href="@Url.Action("Index", "FileAttente")"><i class="bi bi-hourglass"></i><span>File</span></a>
        <a href="@Url.Action("Index", "Lp2m")"><i class="bi bi-grid-1x2"></i><span>LP2M</span></a>
    </nav>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="@Url.Content("~/js/site.js")"></script>
@if (connecte)
{
    <script>
        (function () {
            var segments = location.pathname.split('/').filter(Boolean).map(function (x) { return x.toLowerCase(); });
            document.querySelectorAll('.lp2m-link, .mobile-bottom-nav a').forEach(function (a) {
                var href = (a.getAttribute('href') || '').split('#')[0].split('/').filter(Boolean).map(function (x) { return x.toLowerCase(); });
                var ctrl = href.length ? href[href.length - 1] : null;
                if (ctrl && segments.indexOf(ctrl) !== -1) a.classList.add('actif');
                a.addEventListener('click', function () { document.body.classList.remove('sidebar-open'); });
            });
            var net = document.getElementById('lp2m-net');
            function majReseau() { if (net) net.hidden = navigator.onLine; }
            window.addEventListener('online', majReseau);
            window.addEventListener('offline', majReseau);
            majReseau();
        })();
    </script>
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
