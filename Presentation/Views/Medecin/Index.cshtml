@model List<Medecin>
@{
    ViewData["Title"] = "Médecins";
    var groupes = Model.GroupBy(m => m.Departement?.Nom ?? "Sans service").OrderBy(g => g.Key);
}
<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <h1 class="gh-page-title"><i class="bi bi-person-badge me-2"></i>Corps médical</h1>
        @if (ViewBag.EstAdmin as bool? == true)
        {
            <a href="/Medecin/Nouveau" class="btn btn-primary"><i class="bi bi-plus me-1"></i>Ajouter un médecin</a>
        }
    </div>
</div>
<div class="gh-content">
    @foreach (var groupe in groupes)
    {
        <h5 class="text-muted mb-3 mt-4"><i class="bi bi-diagram-3 me-2"></i>@groupe.Key</h5>
        <div class="row g-3 mb-2">
            @foreach (var m in groupe)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="gh-card gh-medecin-card">
                        <div class="gh-card-body d-flex gap-3">
                            <div class="gh-medecin-avatar"><i class="bi bi-person-badge"></i></div>
                            <div class="flex-fill">
                                <div class="fw-bold">@m.NomComplet</div>
                                <div class="text-muted small">@m.Spécialité</div>
                                @if (!string.IsNullOrEmpty(m.Téléphone))
                                { <div class="small"><i class="bi bi-telephone me-1"></i>@m.Téléphone</div> }
                                @if (!m.Actif)
                                { <span class="badge bg-secondary mt-1">Inactif</span> }
                            </div>
                            <div class="d-flex flex-column gap-1">
                                <a href="/RendezVous?medecinId=@m.Id" class="btn btn-sm btn-outline-primary" title="Planning"><i class="bi bi-calendar3"></i></a>
                                @if (ViewBag.EstAdmin as bool? == true)
                                {
                                    <a href="/Medecin/Modifier/@m.Id" class="btn btn-sm btn-outline-secondary" title="Modifier"><i class="bi bi-pencil"></i></a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
