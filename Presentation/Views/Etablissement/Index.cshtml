@model Etablissement
@{
    ViewData["Title"] = "Établissement";
    var couleurTenant = string.IsNullOrWhiteSpace(Model.Couleur) ? "#0ea5e9" : Model.Couleur;
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-buildings me-2"></i>Établissement / tenant</h1>
            <p class="gh-page-subtitle">Identité, coordonnées et couleur principale de l'application</p>
        </div>
        <a href="@Url.Action("Index", "Lp2m")" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Administration LP2M</a>
    </div>
</div>

<div class="gh-content">
    <form method="post" action="@Url.Action("Index", "Etablissement")">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="gh-card">
                    <div class="gh-card-body">
                        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
                        <div class="row g-3">
                            <div class="col-md-8"><label class="form-label fw-semibold">Nom *</label><input name="Nom" class="form-control" value="@Model.Nom" required /></div>
                            <div class="col-md-4"><label class="form-label fw-semibold">Couleur</label><input type="color" name="Couleur" class="form-control form-control-color" value="@couleurTenant" /></div>
                            <div class="col-12"><label class="form-label fw-semibold">Adresse</label><input name="Adresse" class="form-control" value="@Model.Adresse" /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Téléphone</label><input name="Téléphone" class="form-control" value="@Model.Téléphone" /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Email</label><input type="email" name="Email" class="form-control" value="@Model.Email" /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Site web</label><input name="SiteWeb" class="form-control" value="@Model.SiteWeb" /></div>
                            <div class="col-md-6"><label class="form-label fw-semibold">Directeur</label><input name="Directeur" class="form-control" value="@Model.Directeur" /></div>
                            <div class="col-12"><label class="form-label fw-semibold">Logo URL</label><input name="Logo" class="form-control" value="@Model.Logo" placeholder="https://..." /></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="gh-card mb-3">
                    <div class="gh-card-body">
                        <div class="small text-muted mb-2">Aperçu</div>
                        <div class="p-3 rounded text-white fw-bold" style="background:@couleurTenant">
                            <i class="bi bi-hospital-fill me-2"></i>@Model.Nom
                        </div>
                    </div>
                </div>
                <div class="gh-card">
                    <div class="gh-card-body d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-save me-2"></i>Enregistrer</button>
                        <a href="@Url.Action("Index", "Accueil")" class="btn btn-outline-secondary">Retour accueil</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
