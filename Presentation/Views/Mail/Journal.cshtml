@model List<GestionHopital.Domaine.Models.JournalMail>
@{
    ViewData["Title"] = "Journal des mails";
    int envoyes = Model.Count(m => m.Statut == StatutMail.Envoyé);
    int echecs = Model.Count(m => m.Statut == StatutMail.Echec);
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h1 class="fw-bold mb-1"><i class="bi bi-envelope-check me-2 text-primary"></i>Journal des mails</h1>
        <p class="text-muted mb-0"><span class="text-success fw-semibold">@envoyes envoyé(s)</span>
            @if (echecs > 0) { <span class="text-danger fw-semibold ms-2">@echecs échec(s)</span> }
        </p>
    </div>
    <a href="/Mail/Composer" class="btn btn-primary">
        <i class="bi bi-envelope-plus me-1"></i> Composer un mail
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 opacity-25 d-block mb-2"></i>
                Aucun mail envoyé pour le moment.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Destinataire</th>
                            <th>Objet</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td class="text-nowrap">@m.DateEnvoi.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@m.Destinataire</td>
                            <td class="text-truncate" style="max-width:200px">@m.Sujet</td>
                            <td>
                                @if (m.Statut == StatutMail.Envoyé)
                                { <span class="badge text-bg-success"><i class="bi bi-check2 me-1"></i>Envoyé</span> }
                                else if (m.Statut == StatutMail.Echec)
                                {
                                    <span class="badge text-bg-danger" title="@m.Erreur"><i class="bi bi-x-circle me-1"></i>Échec</span>
                                }
                                else
                                { <span class="badge text-bg-secondary">En attente</span> }
                            </td>
                            <td>
                                <a href="/Mail/Apercu/@m.Id" class="btn btn-sm btn-outline-secondary" title="Voir contenu">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
