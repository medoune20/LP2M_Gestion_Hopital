@model List<GestionHopital.Domaine.Models.JournalMail>
@{
    ViewData["Title"] = "Journal des mails";
    int envoyes = Model.Count(m => m.Statut == StatutMail.Envoyé);
    int echecs = Model.Count(m => m.Statut == StatutMail.Echec);
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-envelope-check me-2"></i>Journal des mails</h1>
            <p class="gh-page-subtitle"><span class="text-success fw-semibold">@envoyes envoyé(s)</span>@if (echecs > 0) { <span class="text-danger fw-semibold ms-2">@echecs échec(s)</span> }</p>
        </div>
        <a href="@Url.Action("Composer", "Mail")" class="btn btn-primary"><i class="bi bi-envelope-plus me-1"></i>Composer un mail</a>
    </div>
</div>

<div class="gh-content">
    <div class="gh-card">
        <div class="gh-card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 opacity-25 d-block mb-2"></i>
                    Aucun mail envoyé pour le moment.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="gh-table table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Destinataire</th>
                                <th>Objet</th>
                                <th>Statut</th>
                                <th>Erreur SMTP</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@m.DateEnvoi.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@m.Destinataire</td>
                                <td class="text-truncate" style="max-width:220px">@m.Sujet</td>
                                <td>
                                    @if (m.Statut == StatutMail.Envoyé)
                                    { <span class="badge text-bg-success"><i class="bi bi-check2 me-1"></i>Envoyé</span> }
                                    else if (m.Statut == StatutMail.Echec)
                                    { <span class="badge text-bg-danger"><i class="bi bi-x-circle me-1"></i>Échec</span> }
                                    else
                                    { <span class="badge text-bg-secondary">En attente</span> }
                                </td>
                                <td class="small text-danger" style="max-width:360px">@m.Erreur</td>
                                <td class="text-end">
                                    <a href="@Url.Action("Apercu", "Mail", new { id = m.Id })" class="btn btn-sm btn-outline-secondary" title="Voir contenu"><i class="bi bi-eye"></i></a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
