@{
    ViewData["Title"] = "Composer un mail";
    var destinataireDefaut = ViewBag.Destinataire as string ?? "";
    var sujetDefaut = ViewBag.Sujet as string ?? "";
    var corpsDefaut = ViewBag.Corps as string ?? "";
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-envelope-plus me-2"></i>Composer un mail</h1>
            <p class="gh-page-subtitle">Envoi SMTP et journalisation des messages</p>
        </div>
        <a href="@Url.Action("Journal", "Mail")" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Journal</a>
    </div>
</div>

<div class="gh-content">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="gh-card">
                <div class="gh-card-body">
                    <form method="post" action="@Url.Action("Composer", "Mail")">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Destinataire</label>
                            <input type="email" name="Destinataire" class="form-control" required placeholder="email@exemple.com" value="@destinataireDefaut" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Objet</label>
                            <input type="text" name="Sujet" class="form-control" required placeholder="Objet du message" value="@sujetDefaut" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Message</label>
                            <textarea name="Corps" class="form-control" rows="8" required placeholder="Contenu du message…">@corpsDefaut</textarea>
                            <div class="form-text">Vous pouvez utiliser des balises HTML basiques (&lt;b&gt;, &lt;br&gt;, &lt;ul&gt;…).</div>
                        </div>

                        <div class="alert alert-info py-2 mb-3" style="font-size:.85rem">
                            <i class="bi bi-info-circle me-1"></i>
                            La configuration SMTP est lue depuis les variables <strong>SMTP_HOST</strong>, <strong>SMTP_PORT</strong>, <strong>SMTP_USER</strong>, <strong>SMTP_PASS</strong>, <strong>SMTP_FROM</strong> et <strong>SMTP_SSL</strong>.
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="@Url.Action("Journal", "Mail")" class="btn btn-outline-secondary">Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-send me-1"></i>Envoyer</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
