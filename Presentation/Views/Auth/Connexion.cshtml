@{
    Layout = null;
    ViewData["Title"] = "Connexion";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion — GestionHopital</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="@Url.Content("~/css/site.css")" />
</head>
<body class="gh-login-body">
    <div class="gh-login-container">
        <div class="gh-login-card">
            <div class="gh-login-header">
                <div class="gh-login-icon"><i class="bi bi-hospital"></i></div>
                <h1 class="gh-login-title">GestionHopital</h1>
                <p class="gh-login-subtitle">Système de gestion hospitalière</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Erreur as string))
            {
                <div class="alert alert-danger py-2">
                    <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Erreur
                </div>
            }

            <form method="post" action="@Url.Action("Connexion", "Auth")" autocomplete="on">
                @Html.AntiForgeryToken()
                <input type="hidden" name="retour" value="@ViewBag.Retour" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Identifiant</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-primary"></i></span>
                        <input type="text" name="login" class="form-control border-start-0 ps-0" placeholder="admin" required autofocus autocomplete="username" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Mot de passe</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-primary"></i></span>
                        <input type="password" name="motDePasse" class="form-control border-start-0 ps-0" placeholder="••••••" required autocomplete="current-password" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                </button>
            </form>

            <div class="text-center mt-4 text-muted small">
                <i class="bi bi-shield-check me-1"></i>Connexion sécurisée &nbsp;|&nbsp;
                <span>admin / admin</span>
            </div>
        </div>
    </div>
</body>
</html>
