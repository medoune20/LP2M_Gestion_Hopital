@model List<RendezVous>
@{
    ViewData["Title"] = "Rendez-vous";
    var médecins = ViewBag.Medecins as List<Medecin> ?? new();
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-calendar3 me-2"></i>Rendez-vous</h1>
            <p class="gh-page-subtitle">@DateTime.Parse(ViewBag.DateFiltre).ToString("dddd dd MMMM yyyy")</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/RendezVous/Nouveau" class="btn btn-primary"><i class="bi bi-calendar-plus me-1"></i>Nouveau RDV</a>
            <a href="/RendezVous/Calendrier" class="btn btn-outline-primary"><i class="bi bi-calendar-week me-1"></i>Calendrier</a>
        </div>
    </div>
</div>

<div class="gh-content">
    <!-- Filtres -->
    <div class="gh-card mb-4">
        <div class="gh-card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Date</label>
                    <input type="date" name="date" class="form-control" value="@ViewBag.DateFiltre" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Médecin</label>
                    <select name="medecinId" class="form-select">
                        <option value="">Tous les médecins</option>
                        @foreach (var m in médecins)
                        {
                            <option value="@m.Id" @(ViewBag.MedecinIdFiltre?.ToString() == m.Id.ToString() ? "selected" : "")>@m.NomComplet</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Statut</label>
                    <select name="statut" class="form-select">
                        <option value="">Tous</option>
                        @foreach (StatutRendezVous s in Enum.GetValues(typeof(StatutRendezVous)))
                        {
                            <option value="@s" @(ViewBag.StatutFiltre?.ToString() == s.ToString() ? "selected" : "")>@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-1">
                    <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-search"></i></button>
                    <a href="/RendezVous" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
                </div>
            </form>
        </div>
    </div>

    <!-- Navigation jours -->
    <div class="d-flex align-items-center gap-2 mb-3">
        @{
            var dateFiltreVal = DateTime.Parse(ViewBag.DateFiltre.ToString());
            var hier = dateFiltreVal.AddDays(-1).ToString("yyyy-MM-dd");
            var demain = dateFiltreVal.AddDays(1).ToString("yyyy-MM-dd");
        }
        <a href="/RendezVous?date=@hier" class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-left"></i></a>
        <a href="/RendezVous?date=@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-primary">Aujourd'hui</a>
        <a href="/RendezVous?date=@demain" class="btn btn-sm btn-outline-secondary"><i class="bi bi-chevron-right"></i></a>
        <span class="ms-2 text-muted">@Model.Count rendez-vous</span>
    </div>

    @if (!Model.Any())
    {
        <div class="gh-card">
            <div class="text-center text-muted py-5">
                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                <p>Aucun rendez-vous pour cette date.</p>
                <a href="/RendezVous/Nouveau" class="btn btn-primary">Planifier un rendez-vous</a>
            </div>
        </div>
    }
    else
    {
        <div class="gh-card">
            <div class="gh-card-body p-0">
                <div class="table-responsive">
                    <table class="gh-table table">
                        <thead>
                            <tr>
                                <th>Heure</th>
                                <th>Patient</th>
                                <th>Médecin</th>
                                <th>Motif</th>
                                <th>Type</th>
                                <th>Statut</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rdv in Model)
                            {
                                <tr class="@(rdv.Statut == StatutRendezVous.EnCours ? "table-warning" : "")">
                                    <td>
                                        <strong class="text-primary">@rdv.DateHeure.ToString("HH:mm")</strong>
                                        <div class="text-muted small">@rdv.Durée min</div>
                                    </td>
                                    <td>
                                        <a href="/Patient/Details/@rdv.PatientId" class="fw-semibold text-decoration-none">@rdv.Patient?.NomComplet</a>
                                        <div class="text-muted small">@rdv.NuméroRDV</div>
                                    </td>
                                    <td>@rdv.Medecin?.NomComplet</td>
                                    <td>@rdv.Motif</td>
                                    <td><span class="badge bg-light text-dark border">@rdv.TypeConsultation</span></td>
                                    <td>
                                        <span class="badge bg-@rdv.StatutCssClass">
                                            <i class="@rdv.StatutIcone me-1"></i>@rdv.Statut
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            @if (rdv.Statut == StatutRendezVous.Planifié)
                                            {
                                                <form method="post" action="/RendezVous/Confirmer" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@rdv.Id" />
                                                    <button class="btn btn-sm btn-outline-success" title="Confirmer"><i class="bi bi-check"></i></button>
                                                </form>
                                            }
                                            @if (rdv.Statut is StatutRendezVous.Planifié or StatutRendezVous.Confirmé)
                                            {
                                                <form method="post" action="/RendezVous/DémarrerConsultation" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@rdv.Id" />
                                                    <button class="btn btn-sm btn-primary" title="Démarrer consultation">
                                                        <i class="bi bi-clipboard2-pulse"></i>
                                                    </button>
                                                </form>
                                                <form method="post" action="/RendezVous/Annuler" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@rdv.Id" />
                                                    <button class="btn btn-sm btn-outline-danger" title="Annuler"><i class="bi bi-x"></i></button>
                                                </form>
                                            }
                                            <a href="/Patient/Details/@rdv.PatientId" class="btn btn-sm btn-outline-secondary" title="Dossier">
                                                <i class="bi bi-folder2-open"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
