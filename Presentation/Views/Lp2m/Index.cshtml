@using GestionHopital.Domaine.Models
@{
    ViewData["Title"] = "LP2M Santé";
    var etabs = ViewBag.Etablissements as List<Etablissement> ?? new();
    var users = ViewBag.Utilisateurs as List<Utilisateur> ?? new();
    var patients = ViewBag.Patients as List<Patient> ?? new();
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-grid-1x2 me-2"></i>Administration LP2M Santé</h1>
            <p class="gh-page-subtitle">Socle de gestion : tenants, profils, utilisateurs, patients, paiements, comptabilité, alertes et téléconsultation.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-light" href="@Url.Action("Index", "Patient")"><i class="bi bi-people me-1"></i>Patients</a>
            <a class="btn btn-outline-light" href="@Url.Action("Index", "RendezVous")"><i class="bi bi-calendar3 me-1"></i>RDV</a>
        </div>
    </div>
</div>

<div class="gh-content">
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3"><div class="gh-metric-card gh-metric-blue"><div class="gh-metric-icon"><i class="bi bi-building"></i></div><div class="gh-metric-value">@etabs.Count</div><div class="gh-metric-label">Tenants</div></div></div>
        <div class="col-6 col-lg-3"><div class="gh-metric-card gh-metric-indigo"><div class="gh-metric-icon"><i class="bi bi-person-gear"></i></div><div class="gh-metric-value">@users.Count</div><div class="gh-metric-label">Utilisateurs</div></div></div>
        <div class="col-6 col-lg-3"><div class="gh-metric-card gh-metric-orange"><div class="gh-metric-icon"><i class="bi bi-people"></i></div><div class="gh-metric-value">@patients.Count</div><div class="gh-metric-label">Patients chargés</div></div></div>
        <div class="col-6 col-lg-3"><div class="gh-metric-card gh-metric-green"><div class="gh-metric-icon"><i class="bi bi-cash-stack"></i></div><div class="gh-metric-value">@string.Format("{0:N0}", ViewBag.TotalRecettesJour ?? 0)</div><div class="gh-metric-label">Recettes jour</div></div></div>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-xl-4"><div class="gh-card h-100"><div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-shield-lock me-2"></i>Profils & utilisateurs</h5></div><div class="gh-card-body"><p class="text-muted">Création des profils, rôles et accès utilisateurs, avec SuperAdmin.</p><a class="btn btn-primary" href="#">Module en cours de finalisation</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="gh-card h-100"><div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-hourglass-split me-2"></i>File d'attente</h5></div><div class="gh-card-body"><p class="text-muted">Suivi des patients à l'accueil, appel, priorité et clôture.</p><a class="btn btn-primary" href="@Url.Action("Index", "RendezVous")">Voir les RDV</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="gh-card h-100"><div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-camera-video me-2"></i>Téléconsultation</h5></div><div class="gh-card-body"><p class="text-muted">Planification de consultations en ligne et notifications patient.</p><a class="btn btn-primary" href="@Url.Action("Index", "Consultation")">Voir consultations</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="gh-card h-100"><div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-cash-coin me-2"></i>Paiements</h5></div><div class="gh-card-body"><p class="text-muted">Encaissement espèces, mobile money, carte et génération des reçus.</p><a class="btn btn-success" href="#">Caisse santé</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="gh-card h-100"><div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-journal-text me-2"></i>Comptabilité</h5></div><div class="gh-card-body"><p class="text-muted">Écritures automatiques des recettes et suivi financier.</p><a class="btn btn-primary" href="#">Voir comptabilité</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="gh-card h-100"><div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-bell me-2"></i>Alertes & mails</h5></div><div class="gh-card-body"><p class="text-muted">Alertes opérationnelles, mails patients et journal d'envoi.</p><a class="btn btn-primary" href="#">Centre d'alertes</a></div></div></div>
    </div>
</div>
