@model List<Departement>
@{
    ViewData["Title"] = "Services & Lits";
}
<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <h1 class="gh-page-title"><i class="bi bi-diagram-3 me-2"></i>Services hospitaliers</h1>
        @if (ViewBag.EstAdmin as bool? == true)
        {
            <a href="/Departement/Nouveau" class="btn btn-primary"><i class="bi bi-plus me-1"></i>Nouveau service</a>
        }
    </div>
</div>
<div class="gh-content">
    <div class="row g-3">
        @foreach (var d in Model)
        {
            var libre = d.LitsLibres;
            var total = d.Lits.Count;
            var occupé = d.LitsOccupés;
            var pct = total > 0 ? (int)((double)occupé / total * 100) : 0;
            var couleurBar = pct >= 90 ? "danger" : pct >= 70 ? "warning" : "success";
            <div class="col-md-6 col-lg-4">
                <div class="gh-card h-100">
                    <div class="gh-card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-0">@d.Nom</h5>
                                @if (!string.IsNullOrEmpty(d.Localisation))
                                { <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@d.Localisation</small> }
                            </div>
                            <span class="badge bg-primary">@d.Medecins.Count médecin(s)</span>
                        </div>

                        @if (!string.IsNullOrEmpty(d.ChefService))
                        {
                            <div class="mb-2 small"><i class="bi bi-person-badge me-1 text-primary"></i>Chef: <strong>@d.ChefService</strong></div>
                        }
                        @if (!string.IsNullOrEmpty(d.Téléphone))
                        {
                            <div class="mb-2 small"><i class="bi bi-telephone me-1"></i>@d.Téléphone</div>
                        }

                        @if (total > 0)
                        {
                            <div class="mt-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>Occupation des lits</span>
                                    <span><strong>@occupé / @total</strong></span>
                                </div>
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar bg-@couleurBar" style="width:@pct%"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-1 small text-muted">
                                    <span><i class="bi bi-check-circle text-success me-1"></i>@libre libres</span>
                                    <span>@pct% occupé</span>
                                </div>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-3">
                            @if (total > 0)
                            {
                                <a href="/Departement/Lits/@d.Id" class="btn btn-sm btn-outline-primary flex-fill">
                                    <i class="bi bi-grid me-1"></i>Voir les lits
                                </a>
                            }
                            <a href="/Hospitalisation/Nouvelle" class="btn btn-sm btn-outline-warning flex-fill">
                                <i class="bi bi-person-check me-1"></i>Admettre
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
