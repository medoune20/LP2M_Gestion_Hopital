@model Patient
@{
    ViewData["Title"] = "Nouveau patient";
}

<div class="gh-page-header">
    <div class="gh-page-header-inner">
        <div>
            <h1 class="gh-page-title"><i class="bi bi-person-plus me-2"></i>Enregistrer un patient</h1>
            <p class="gh-page-subtitle">Création d'un nouveau dossier patient</p>
        </div>
        <a href="/Patient" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

<div class="gh-content">
    <form method="post" action="/Patient/Nouveau">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <!-- Identité -->
            <div class="col-lg-8">
                <div class="gh-card mb-3">
                    <div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-person me-2"></i>Identité du patient</h5></div>
                    <div class="gh-card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                                <input type="text" name="Nom" class="form-control" value="@Model.Nom" required placeholder="Nom de famille" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Prénom <span class="text-danger">*</span></label>
                                <input type="text" name="Prénom" class="form-control" value="@Model.Prénom" required placeholder="Prénom(s)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Date de naissance <span class="text-danger">*</span></label>
                                <input type="date" name="DateNaissance" class="form-control" value="@Model.DateNaissance.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Sexe</label>
                                <select name="Sexe" class="form-select">
                                    @foreach (SexePatient s in Enum.GetValues(typeof(SexePatient)))
                                    {
                                        <option value="@((int)s)" selected="@(Model.Sexe == s)">@s</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Groupe sanguin</label>
                                <select name="GroupeSanguin" class="form-select">
                                    @foreach (GroupeSanguin g in Enum.GetValues(typeof(GroupeSanguin)))
                                    {
                                        <option value="@((int)g)" selected="@(Model.GroupeSanguin == g)">@Model.GroupeSanguinLibellé</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="gh-card mb-3">
                    <div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-geo-alt me-2"></i>Coordonnées</h5></div>
                    <div class="gh-card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold">Adresse</label>
                                <input type="text" name="Adresse" class="form-control" value="@Model.Adresse" placeholder="Quartier, Ville" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Téléphone</label>
                                <input type="tel" name="Téléphone" class="form-control" value="@Model.Téléphone" placeholder="+225 07 XX XX XX XX" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="email" name="Email" class="form-control" value="@Model.Email" placeholder="patient@email.com" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="gh-card mb-3">
                    <div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-clipboard2-pulse me-2"></i>Informations médicales</h5></div>
                    <div class="gh-card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Allergies connues</label>
                                <textarea name="Allergies" class="form-control" rows="2" placeholder="Pénicilline, aspirine, latex...">@Model.Allergies</textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Antécédents médicaux</label>
                                <textarea name="Antécédents" class="form-control" rows="3" placeholder="Hypertension, diabète, chirurgies passées...">@Model.Antécédents</textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact urgence + Assurance -->
            <div class="col-lg-4">
                <div class="gh-card mb-3">
                    <div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-telephone-outbound me-2"></i>Contact d'urgence</h5></div>
                    <div class="gh-card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nom & Lien</label>
                            <input type="text" name="NomContactUrgence" class="form-control" value="@Model.NomContactUrgence" placeholder="Ex: Koné Marie (épouse)" />
                        </div>
                        <div>
                            <label class="form-label fw-semibold">Téléphone</label>
                            <input type="tel" name="TéléphoneUrgence" class="form-control" value="@Model.TéléphoneUrgence" placeholder="+225 07 XX XX XX XX" />
                        </div>
                    </div>
                </div>

                <div class="gh-card mb-3">
                    <div class="gh-card-header"><h5 class="gh-card-title"><i class="bi bi-shield-check me-2"></i>Couverture sociale</h5></div>
                    <div class="gh-card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">N° Sécurité sociale</label>
                            <input type="text" name="NuméroSécuritéSociale" class="form-control" value="@Model.NuméroSécuritéSociale" />
                        </div>
                        <div>
                            <label class="form-label fw-semibold">Mutuelle / Assurance</label>
                            <input type="text" name="Mutuelle" class="form-control" value="@Model.Mutuelle" placeholder="CNPS, MUGEF-CI..." />
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-save me-2"></i>Enregistrer le patient
                    </button>
                    <a href="/Patient" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </div>
        </div>
    </form>
</div>
